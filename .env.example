# ==========================================
# AI Core Service Configuration
# ==========================================

# ------------------------------------------
# Application
# ------------------------------------------
APP_NAME=AI Core Service
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true


# ------------------------------------------
# AI Provider
# ------------------------------------------
AI_PROVIDER=openrouter

# Obtain your API key from:
# https://openrouter.ai/
OPENROUTER_API_KEY=

# Default free model
AI_MODEL=google/gemma-3-27b-it:free

TEMPERATURE=0.0
MAX_TOKENS=1024


# ------------------------------------------
# Logging
# ------------------------------------------
LOG_LEVEL=INFO